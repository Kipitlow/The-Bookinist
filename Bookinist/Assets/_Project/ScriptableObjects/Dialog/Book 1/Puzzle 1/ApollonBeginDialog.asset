  m_Script: {fileID: 11500000, guid: 8b3166a8f967c484b9a51f910ebc5044, type: 3}
  m_Name: ApollonBeginDialog
  m_EditorClassIdentifier: 
  NPCName: Apollon
  lines:
  - "Bien le bonjour, bouquiniste ! Que viens-tu faire dans cette \xE9pop\xE9e ?"
  - "Tu as besoin de ma lyre ? Pour Orph\xE9e ? "
  - "Tr\xE8s bien, puisque tu le demandes, en \xE9change d'une faveur."
  - Offre moi des choses dignes du dieu des arts que je suis.
  - "Fais pencher la balance de ton c\xF4t\xE9, alors je te donnerai ma lyre."
  IsShopNPC: 0
  isLoopable: 0
